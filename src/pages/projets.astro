---
import Layout from '../layouts/Layout.astro';
import ProjetsBody from '../components/pages/ProjetsBody.astro';
import { elementorPages } from '../data/elementor-pages';
import ZoneIntervention from '../components/ZoneIntervention.astro';

const meta = elementorPages['projets'];
const title = `Projets - C CHEZ TOÎT`;
const description = `Nos projets Chaque projet est pour nous l’occasion de prouver notre expertise et notre sérieux. Voici un aperçu de nos interventions réussies, qui valorisent durablement l’habitat de nos clients. Projet en vedette Nettoyage & Traitement de Toiture Toulouse, Haute-Garonne Nous avons réalisé un démoussage complet de cette toiture en tuiles, suivi d’un traitement hydrofuge longue […]`;
const bodyAttrs = {
  "itemscope": "itemscope",
  "itemtype": "https://schema.org/WebPage"
};
const elementorPostId = meta.bodyClass.match(/page-id-(\d+)/)?.[1] ?? '0';
---
<Layout
  title={title}
  description={description}
  htmlLang="fr-FR"
  bodyClass={meta.bodyClass}
  bodyAttrs={bodyAttrs}
  elementor
  elementorPostCss={meta.elementorPostCss}
  elementorPostId={Number(elementorPostId)}
  canonical="/"
>
  <ProjetsBody />
  <ZoneIntervention variant="soft" />

</Layout>
