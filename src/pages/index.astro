---
import Layout from '../layouts/Layout.astro';
import HomeBody from '../components/pages/HomeBody.astro';
import { elementorPages } from '../data/elementor-pages';
import ZoneIntervention from '../components/ZoneIntervention.astro';

const meta = elementorPages['home'];
const title = `Accueil - C CHEZ TOÎT`;
const description = `Haute-garonne (31) Experts du nettoyage extérieur et de la couverture à Toulouse et ses alentours Démoussage, hydrofuge, réparation de faîtage, gouttières et zinguerie : des prestations rapides, fiables et garanties, avec un devis gratuit en moins de 24 h. Demander un devis gratuit Nettoyage de toiture, façade & terrasse à Toulouse (31) et ses alentours […]`;
const bodyAttrs = {
  "itemscope": "itemscope",
  "itemtype": "https://schema.org/WebPage"
};
const elementorPostId = meta.bodyClass.match(/page-id-(\d+)/)?.[1] ?? '0';
---
<Layout
  title={title}
  description={description}
  htmlLang="fr-FR"
  bodyClass={meta.bodyClass}
  bodyAttrs={bodyAttrs}
  elementor
  elementorPostCss={meta.elementorPostCss}
  elementorPostId={Number(elementorPostId)}
  canonical="/"
>
  <HomeBody />
  <ZoneIntervention variant="soft" />

</Layout>
