---
import Layout from '../layouts/Layout.astro';
import ServicesBody from '../components/pages/ServicesBody.astro';
import { elementorPages } from '../data/elementor-pages';
import ZoneIntervention from '../components/ZoneIntervention.astro';
import ServiceSchema from '../components/seo/ServiceSchema.astro';
import ReviewSchema from '../components/seo/ReviewSchema.astro';

const meta = elementorPages['services'];
const title = `Services - C CHEZ TOÎT`;
const description = `Nos Services C Chez Toit vous accompagne dans l’entretien, la rénovation et la protection de votre habitat. Toiture, façade, terrasse ou gouttières : nos solutions sont sur mesure, durables et garanties pour préserver la valeur de votre maison. Nos Services de Toiture Nous intervenons pour protéger, entretenir et valoriser vos toitures dans toute la Haute-Garonne. […]`;
const bodyAttrs = {
  "itemscope": "itemscope",
  "itemtype": "https://schema.org/WebPage"
};
const elementorPostId = meta.bodyClass.match(/page-id-(\d+)/)?.[1] ?? '0';
---
<Layout
  title={title}
  description={description}
  htmlLang="fr-FR"
  bodyClass={meta.bodyClass}
  bodyAttrs={bodyAttrs}
  elementor
  elementorPostCss={meta.elementorPostCss}
  elementorPostId={Number(elementorPostId)}
  canonical="/services"
  ogType="article"
>
  <ServicesBody />
  <ZoneIntervention variant="light" />
  <ServiceSchema
    name="Services de nettoyage et couverture"
    description="Services professionnels de nettoyage extérieur, démoussage, hydrofuge, réparation de toiture, gouttières et zinguerie dans toute la Haute-Garonne."
    areaServed={["Toulouse", "Blagnac", "Colomiers", "Tournefeuille", "Muret", "Balma", "L'Union", "Ramonville-Saint-Agne", "Cugnaux", "Plaisance-du-Touch", "Castanet-Tolosan", "Saint-Orens-de-Gameville"]}
    hasOfferCatalog={{
      name: "Nos services",
      itemOffered: [
        { name: "Démoussage toiture", description: "Élimination complète des mousses, lichens et végétaux pour préserver votre toiture" },
        { name: "Nettoyage façade", description: "Nettoyage en douceur des façades pour redonner de l'éclat à votre habitat" },
        { name: "Hydrofuge toiture et façade", description: "Application de traitement hydrofuge pour une protection durable contre l'humidité" },
        { name: "Réparation de faîtage", description: "Remplacement et réparation des faîtières pour garantir l'étanchéité" },
        { name: "Nettoyage et réparation gouttières", description: "Entretien et réparation du système d'évacuation des eaux pluviales" },
        { name: "Zinguerie", description: "Travaux de zinguerie pour une toiture étanche et durable" },
      ],
    }}
  />
  <ReviewSchema
    itemReviewed="Services C CHEZ TOÎT"
    reviews={[
      { author: "Nadia Benali", reviewRating: { ratingValue: 5 }, reviewBody: "Nous avons fait appel à C Chez Toit pour le nettoyage de notre terrasse. Résultat impeccable.", datePublished: "2025-01-15" },
      { author: "Sophie Laurent", reviewRating: { ratingValue: 5 }, reviewBody: "Notre façade a retrouvé sa couleur d'origine après le nettoyage. Travail soigné.", datePublished: "2025-01-10" },
      { author: "Marc Dupont", reviewRating: { ratingValue: 4.5 }, reviewBody: "Intervention rapide et efficace pour la réparation de nos gouttières.", datePublished: "2025-01-05" },
    ]}
    aggregateRating={{ ratingValue: 4.8, reviewCount: 15 }}
  />
</Layout>
