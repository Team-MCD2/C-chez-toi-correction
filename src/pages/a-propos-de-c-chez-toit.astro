---
import Layout from '../layouts/Layout.astro';
import AProposBody from '../components/pages/AProposBody.astro';
import { elementorPages } from '../data/elementor-pages';
import ZoneIntervention from '../components/ZoneIntervention.astro';

const meta = elementorPages['a-propos-de-c-chez-toit'];
const title = `À propos - C CHEZ TOÎT`;
const description = `À Propos de Nous Chez C Chez Toit, nous mettons notre savoir-faire et notre expérience au service de vos toitures, façades et terrasses. Implantés à Toulouse, nous connaissons parfaitement les spécificités locales et proposons des solutions adaptées, durables et garanties. À Propos de Nous Chez C Chez Toit, nous mettons notre expertise et notre passion […]`;
const bodyAttrs = {
  "itemscope": "itemscope",
  "itemtype": "https://schema.org/WebPage"
};
const elementorPostId = meta.bodyClass.match(/page-id-(\d+)/)?.[1] ?? '0';
---
<Layout
  title={title}
  description={description}
  htmlLang="fr-FR"
  bodyClass={meta.bodyClass}
  bodyAttrs={bodyAttrs}
  elementor
  elementorPostCss={meta.elementorPostCss}
  elementorPostId={Number(elementorPostId)}
  canonical="/"
>
  <AProposBody />
  <ZoneIntervention variant="soft" />

</Layout>
