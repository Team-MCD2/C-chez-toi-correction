---
import Layout from '../layouts/Layout.astro';
import PolitiqueBody from '../components/pages/PolitiqueBody.astro';
import { elementorPages } from '../data/elementor-pages';

const meta = elementorPages['politique-de-confidentialite'];
const title = `Politique de confidentialité - C CHEZ TOÎT`;
const description = `Nos Politiques de confidentialité Dernière mise à jour : 30/01/2026 La présente politique de confidentialité décrit la manière dont C Chez Toit (ci-après « nous », « notre » ou « nos ») collecte, utilise et protège les données personnelles des utilisateurs du site https://c-chez-toit.fr. 1. Responsable du traitement Le responsable du traitement des données […]`;
const bodyAttrs = {
  "itemscope": "itemscope",
  "itemtype": "https://schema.org/WebPage"
};
const elementorPostId = meta.bodyClass.match(/page-id-(\d+)/)?.[1] ?? '0';
---
<Layout
  title={title}
  description={description}
  htmlLang="fr-FR"
  bodyClass={meta.bodyClass}
  bodyAttrs={bodyAttrs}
  elementor
  elementorPostCss={meta.elementorPostCss}
  elementorPostId={Number(elementorPostId)}
  canonical="../assets/politique-de-confidentialite/index.html"
>
  <PolitiqueBody />

</Layout>
