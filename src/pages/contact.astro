---
import Layout from '../layouts/Layout.astro';
import ContactBody from '../components/pages/ContactBody.astro';
import { elementorPages } from '../data/elementor-pages';

const meta = elementorPages['contact'];
const title = `Contact - C CHEZ TOÎT`;
const description = `Contactez-nous Protégez et valorisez votre maison avec C Chez Toit. Demandez dès maintenant votre devis gratuit : réponse garantie sous 24 h. Demandez un devis gratuit ! Obtenez rapidement une estimation claire et personnalisée pour vos travaux de toiture, façade, terrasse ou gouttières. Nos devis sont gratuits et envoyés sous 24 h, sans engagement. Chez […]`;
const bodyAttrs = {
  "itemscope": "itemscope",
  "itemtype": "https://schema.org/WebPage"
};
const elementorPostId = meta.bodyClass.match(/page-id-(\d+)/)?.[1] ?? '0';
---
<Layout
  title={title}
  description={description}
  htmlLang="fr-FR"
  bodyClass={meta.bodyClass}
  bodyAttrs={bodyAttrs}
  elementor
  elementorPostCss={meta.elementorPostCss}
  elementorPostId={Number(elementorPostId)}
  canonical="/"
>
  <ContactBody />

</Layout>
