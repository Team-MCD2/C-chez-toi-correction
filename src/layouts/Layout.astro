---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import LocalBusinessSchema from '../components/seo/LocalBusinessSchema.astro';
import VisualEnhancements from '../components/VisualEnhancements.astro';
import ElementorPageStyles from '../components/site/ElementorPageStyles.astro';
import ElementorRuntime from '../components/site/ElementorRuntime.astro';
import BaseHead from '../components/BaseHead.astro';

interface Props {
  title?: string;
  htmlLang?: string;
  bodyClass?: string;
  bodyAttrs?: Record<string, string>;
  /** @deprecated Utiliser elementorPostCss — conserve compatibilite zone */
  useBaseHead?: boolean;
  /** CSS Elementor de la page (post-390, etc.) */
  elementorPostCss?: string[];
  /** ID Elementor pour la config frontend (video, compteurs) */
  elementorPostId?: number;
  /** Charge les styles/scripts Elementor (pages migrees) */
  elementor?: boolean;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonical?: string;
}

const SITE_NAME = 'C CHEZ TOÎT';
const DEFAULT_OG_IMAGE = '/assets/content/uploads/2025/08/logo-ccheztoit-blanc-scaled-1024x1024.png';

const {
  title = '',
  htmlLang = 'fr-FR',
  bodyClass = '',
  bodyAttrs = {},
  useBaseHead = false,
  elementorPostCss = [],
  elementorPostId = 0,
  elementor = false,
  description = '',
  ogImage = DEFAULT_OG_IMAGE,
  ogType = 'website',
  canonical,
} = Astro.props;

const canonicalHref = canonical ?? Astro.url.pathname;
const loadElementor = elementor || elementorPostCss.length > 0;
---
<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalHref} />
    <meta name="theme-color" content="#EA559D" />
    <meta name="format-detection" content="telephone=no" />

    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="fr_FR" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="//fonts.googleapis.com" />

    <link rel="icon" type="image/png" sizes="150x150" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="150x150" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    {loadElementor ? (
      <ElementorPageStyles pageCss={elementorPostCss} />
    ) : useBaseHead ? (
      <BaseHead />
    ) : null}

    <LocalBusinessSchema />
    <link rel="stylesheet" href="/assets/custom-fixes.css?v=2026-05-07-3" />
  </head>
  <body class={bodyClass} {...bodyAttrs}>
    <a href="#content" class="skip-link screen-reader-text">Aller au contenu</a>
    {loadElementor ? (
      <div class="hfeed site" id="page">
        <Header />
        <slot />
        <Footer />
      </div>
    ) : (
      <>
        <a href="#main-content" class="skip-link">Aller au contenu principal</a>
        <Header />
        <main id="main-content">
          <slot />
        </main>
        <Footer />
      </>
    )}
    {loadElementor && <ElementorRuntime elementorPostId={elementorPostId} />}
    <VisualEnhancements />
    <script src="https://mail-form-xi.vercel.app/sdk.js"></script>
  </body>
</html>
